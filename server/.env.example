# Server environment variables
# Copy this to .env and fill in your values

# ── Auth ──────────────────────────────────────────────────────────
# Google OAuth Client ID (create at console.cloud.google.com)
GOOGLE_CLIENT_ID=YOUR_GOOGLE_CLIENT_ID.apps.googleusercontent.com

# Secret key for signing JWT tokens (change this in production!)
JWT_SECRET=change-me-to-a-long-random-string

# ── AI / RAG Pipeline ──────────────────────────────────────────────
# OpenAI API key for GPT-3.5-turbo explanations + embeddings
# OPTIONAL: without this, the system uses HuggingFace sentence-transformers (free)
OPENAI_API_KEY=sk-...

# ── Job Portals (optional) ─────────────────────────────────────────
# Adzuna free dev API (sign up at developer.adzuna.com)
ADZUNA_APP_ID=
ADZUNA_APP_KEY=
